#!/usr/bin/env bash
# pre-push hook: gitleaksлЎњ pushн•  commitм—ђм„њ secret кІЂм¶њ
#
# 2л‹Ёкі„ Secret Scan:
#   1) Local:  gitleaks (pre-push hook)
#   2) Remote: trufflehog (GitHub Actions)

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
export PATH="/run/current-system/sw/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

command -v gitleaks >/dev/null 2>&1 || {
  echo "WARNING: gitleaks not found, skipping secret scan"
  exit 0
}

z40="0000000000000000000000000000000000000000"

while read -r local_ref local_oid remote_ref remote_oid; do
  if [ "$local_oid" = "$z40" ]; then
    continue
  fi

  if [ "$remote_oid" = "$z40" ]; then
    range="$local_oid"
  else
    range="$remote_oid..$local_oid"
  fi

  if ! gitleaks git --log-opts="$range" --verbose --no-banner 2>&1; then
    echo ""
    echo "ERROR: gitleaks detected secrets in commits being pushed."
    echo "  Run 'gitleaks git --log-opts=\"$range\" -v' to see details."
    echo "  Or add false positives to .gitleaksignore"
    exit 1
  fi
done

exit 0
